        <!-- boxed legend: two named arrow roles -->
        <mxCell id="legend" value="&lt;b&gt;arrows&lt;/b&gt;&lt;br&gt;&lt;span style='color:#3B6FB0'&gt;→  key / value · head READS this stream (QK)&lt;/span&gt;&lt;br&gt;&lt;span style='color:#D08A3A'&gt;→  query / output · head WRITES this stream (OV)&lt;/span&gt;" style="rounded=1;fillColor=#FFFFFF;strokeColor=#C9CDD4;fontColor=#1F2329;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;html=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
