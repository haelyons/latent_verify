          <mxGeometry x="26" y="404" width="52" height="14" as="geometry"/>
        </mxCell>

        <!-- faint neutral alignment rules (one colour) -->
        <mxCell id="gA" value="" style="endArrow=none;dashed=1;strokeColor=#C9CDD4;opacity=40;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="240" y="96" as="sourcePoint"/><mxPoint x="240" y="430" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="gB" value="" style="endArrow=none;dashed=1;strokeColor=#C9CDD4;opacity=40;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="460" y="96" as="sourcePoint"/><mxPoint x="460" y="430" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="gC" value="" style="endArrow=none;dashed=1;strokeColor=#C9CDD4;opacity=40;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="690" y="96" as="sourcePoint"/><mxPoint x="690" y="430" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- output node (late) -->
        <mxCell id="out" value="&lt;b&gt;output&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#6B7280'&gt;White → “Yellow”&lt;/span&gt;" style="rounded=1;fillColor=#C9E9D8;strokeColor=#6FB394;fontColor=#1F2329;fontSize=13;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="96" width="150" height="50" as="geometry"/>
