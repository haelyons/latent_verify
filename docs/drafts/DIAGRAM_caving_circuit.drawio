        <!-- doubt heads (mid) -->
        <mxCell id="heads" value="&lt;b&gt;Doubt heads&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#6B7280'&gt;×5 · L?.H? · mid layers&lt;/span&gt;" style="rounded=1;fillColor=#F4D8B0;strokeColor=#C98A4A;fontColor=#1F2329;fontSize=13;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="220" width="224" height="60" as="geometry"/>
        </mxCell>

        <!-- position tokens (bottom edge = data axis) -->
        <mxCell id="tokChallenge" value="&lt;b&gt;challenge&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;color:#6B7280'&gt;“…Are you sure?”&lt;/span&gt;" style="rounded=1;fillColor=#F2F3F5;strokeColor=#C9CDD4;fontColor=#1F2329;fontSize=12;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="430" width="180" height="46" as="geometry"/>
