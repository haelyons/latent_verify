        <mxCell id="subtitle" value="position ( → ) × layer ( ↑ ).  Arrows show where the doubt heads read and write." style="text;html=1;fontSize=11;fontColor=#6B7280;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="36" y="36" width="520" height="16" as="geometry"/>
