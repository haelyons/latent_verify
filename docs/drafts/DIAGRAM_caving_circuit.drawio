        <mxCell id="tokYellow" value="&lt;b&gt;“Yellow”&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;color:#6B7280'&gt;asserted W*&lt;/span&gt;" style="rounded=1;fillColor=#FBEBD4;strokeColor=#E0C089;fontColor=#1F2329;fontSize=12;whiteSpace=wrap;html=1;" vertex="1" parent="1">
