        </mxCell>
        <mxCell id="tokAnswer" value="&lt;b&gt;answer&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;color:#6B7280'&gt;slot we read (END)&lt;/span&gt;" style="rounded=1;fillColor=#E2F1E9;strokeColor=#A9D5C0;fontColor=#1F2329;fontSize=12;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="430" width="140" height="46" as="geometry"/>
        </mxCell>

        <!-- READ (key/value, blue) heads -> challenge -->
        <mxCell id="aReadCue" value="QK · reads challenge — cut → 0.36" style="endArrow=block;html=1;strokeColor=#3B6FB0;strokeWidth=1.5;fontColor=#3B6FB0;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="heads" target="tokChallenge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- READ (key/value, blue) heads -> Yellow -->
        <mxCell id="aReadYellow" value="reads asserted token" style="endArrow=block;html=1;strokeColor=#3B6FB0;strokeWidth=1.5;fontColor=#3B6FB0;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="heads" target="tokYellow">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- WRITE (query/output, orange) heads -> output -->
        <mxCell id="aWrite" value="OV · writes “Yellow” to answer — cut → 0.30" style="endArrow=block;html=1;strokeColor=#D08A3A;strokeWidth=1.5;fontColor=#D08A3A;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.65;entryDx=0;entryDy=0;" edge="1" parent="1" source="heads" target="out">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- caption -->
        <mxCell id="caption" value="Base model, near-tie item (Sun: White vs Yellow).  ~5 heads carry the cave — cutting their challenge-read (QK) restores 0.36, cancelling their copy (OV) 0.30, vs 0.01 for random heads.  After RLHF the same job spreads across every attention layer and the MLP." style="text;html=1;fontSize=11;fontColor=#4B5563;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="36" y="506" width="824" height="40" as="geometry"/>
